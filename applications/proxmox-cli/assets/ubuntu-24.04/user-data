#cloud-config
autoinstall:
  version: 1
  source:
    id: ubuntu-server-minimal
  updates: security
  apt:
    mirror-selection:
      primary:
        - uri: http://mirrors.aliyun.com/ubuntu
        - uri: http://mirrors.tuna.tsinghua.edu.cn/ubuntu
        - uri: http://archive.ubuntu.com/ubuntu
    fallback: offline-install
    geoip: false
  shutdown: poweroff
  early-commands:
    - sh -c 'for f in /var/log/installer/subiquity-server-debug.log /var/log/installer/curtin-install.log /var/log/cloud-init.log; do if [ -f "$f" ]; then echo "[early-log-proof] exists $f"; ls -l "$f"; else echo "[early-log-proof] missing $f"; fi; done >/dev/ttyS0 2>&1'
    - sh -c 'tail -n 0 -F /var/log/installer/subiquity-server-debug.log /var/log/installer/curtin-install.log /var/log/cloud-init.log >/dev/ttyS0 2>&1 & echo $! >/run/autoinstall-serial-tail.pid'
  identity:
    hostname: ubuntu-single-disk
    username: cloud
    password: "$6$ZUnV4ZxZwGP.Dfzm$xNfrfEtV/S.jsqfdj.Uv5n.7hJGR79Bz1.3tYZUys70T5YvQBZaE2cFUtn1zD1xHZVWlA/SGZP1lXiUOVQ7gD."
  ssh:
    install-server: true
    allow-pw: true
  packages:
    - qemu-guest-agent
  late-commands:
    - sh -c 'if [ -s /run/autoinstall-serial-tail.pid ]; then kill "$(cat /run/autoinstall-serial-tail.pid)" 2>/dev/null || true; fi'
    - curtin in-target --target=/target -- systemctl enable serial-getty@ttyS0.service
    - curtin in-target --target=/target -- systemctl enable qemu-guest-agent.service
