#cloud-config
autoinstall:
  version: 1
  source:
    id: ubuntu-server-minimal
  updates: security
  apt:
    mirror-selection:
      primary:
        - uri: http://mirrors.aliyun.com/ubuntu
        - uri: http://mirrors.tuna.tsinghua.edu.cn/ubuntu
        - uri: http://archive.ubuntu.com/ubuntu
    fallback: offline-install
    geoip: false
  shutdown: poweroff
  early-commands:
    - sh -c 'for f in /var/log/installer/subiquity-server-debug.log /var/log/installer/curtin-install.log /var/log/cloud-init.log /target/var/log/apt/term.log /target/var/log/apt/history.log /target/var/log/dpkg.log; do if [ -f "$f" ]; then echo "[early-log-proof] exists $f"; ls -l "$f"; else echo "[early-log-proof] missing $f"; fi; done >/dev/ttyS0 2>&1'
    - sh -c 'tail -n 0 -F /var/log/installer/subiquity-server-debug.log /var/log/installer/curtin-install.log /var/log/cloud-init.log /target/var/log/apt/term.log /target/var/log/apt/history.log /target/var/log/dpkg.log >/dev/ttyS0 2>&1 &'
    - sh -c 'while true; do echo "[install-heartbeat] $(date -Is)"; ps -eo pid,ppid,stat,etime,cmd | grep -E "curtin|in-target|apt|dpkg|grub|initramfs" | grep -v grep || true; sleep 30; done >/dev/ttyS0 2>&1 &'
  identity:
    hostname: ubuntu-single-disk
    username: cloud
    password: "$6$ZUnV4ZxZwGP.Dfzm$xNfrfEtV/S.jsqfdj.Uv5n.7hJGR79Bz1.3tYZUys70T5YvQBZaE2cFUtn1zD1xHZVWlA/SGZP1lXiUOVQ7gD."
  ssh:
    install-server: true
    allow-pw: true
  packages:
    - qemu-guest-agent
  late-commands:
    - curtin in-target --target=/target -- systemctl enable serial-getty@ttyS0.service
    - curtin in-target --target=/target -- systemctl enable qemu-guest-agent.service
